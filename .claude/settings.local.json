{
  "permissions": {
    "allow": [
      "Bash(npm install:*)",
      "Bash(node scripts/gen-skill-docs.mjs:*)",
      "Bash(node scripts/skill-check.mjs:*)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node ./scripts/hooks/session-start.mjs 2>/dev/null || true",
            "timeout": 5000
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node ./scripts/hooks/session-end.mjs 2>/dev/null || true",
            "timeout": 5000
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node ./scripts/hooks/subagent-stop.mjs 2>/dev/null || true",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "memory_store",
        "hooks": [
          {
            "type": "command",
            "command": "node ./scripts/hooks/post-memory-store.mjs 2>/dev/null || true",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node ./scripts/hooks/pre-compact.mjs 2>/dev/null || true",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
